import numpy as np
from scipy.stats import linregress


class SmartMoneySignalEngine:

    def __init__(self):
        self.round_step = 10

    def market_structure(self, df):

        if len(df) < 5:
            return "UNKNOWN"

        recent_high = df["high"].iloc[-1]
        prev_high = df["high"].iloc[-3]

        recent_low = df["low"].iloc[-1]
        prev_low = df["low"].iloc[-3]

        if recent_high > prev_high and recent_low > prev_low:
            return "BULLISH"

        if recent_high < prev_high and recent_low < prev_low:
            return "BEARISH"

        return "RANGE"

    def trend(self, df):

        closes = df["close"].tail(20)

        x = np.arange(len(closes))

        slope, _, _, _, _ = linregress(x, closes)

        if slope > 0:
            return "UP"

        if slope < 0:
            return "DOWN"

        return "SIDEWAYS"

    def zones(self, df):

        buyer_zone = df["low"].tail(50).quantile(0.15)

        seller_zone = df["high"].tail(50).quantile(0.85)

        return buyer_zone, seller_zone

    def generate_signal(self, df):

        buy_score = 0
        sell_score = 0

        structure = self.market_structure(df)

        trend = self.trend(df)

        buyer_zone, seller_zone = self.zones(df)

        price = df["close"].iloc[-1]

        if structure == "BULLISH":
            buy_score += 30

        if structure == "BEARISH":
            sell_score += 30

        if trend == "UP":
            buy_score += 30

        if trend == "DOWN":
            sell_score += 30

        if price <= buyer_zone:
            buy_score += 20

        if price >= seller_zone:
            sell_score += 20

        if buy_score >= 60 and buy_score > sell_score:
            signal = "BUY"

        elif sell_score >= 60 and sell_score > buy_score:
            signal = "SELL"

        else:
            signal = "WAIT"

        return {
            "signal": signal,
            "buy_score": buy_score,
            "sell_score": sell_score,
            "price": price,
            "trend": trend,
            "structure": structure
        }
